# ============================================================
# RAG Chatbot — Backend Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── LLM ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini             # model dùng để generate
ANTHROPIC_API_KEY=sk-ant-...         # chỉ cần nếu dùng Claude
LLM_PROVIDER=gemini
GEMINI_API_KEY=điên key của gemini # bắt buộc  
GEMINI_MODEL=gemini-2.5-flash                 # openai | anthropic

# ── Embedding ────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=128

# ── Vector DB (chọn một) ─────────────────────────────────────
VECTOR_DB_PROVIDER=qdrant         # pinecone | weaviate | qdrant

## Pinecone
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=rag-chatbot
PINECONE_ENVIRONMENT=us-east-1-aws

## Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=...
WEAVIATE_CLASS_NAME=Document

## Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=... # thích có db thì điền vào, không thì ko cần
QDRANT_COLLECTION_NAME=rag-chatbot

# ── BM25 Sparse Index ────────────────────────────────────────
BM25_STORE_PATH=./data/bm25_index

# ── Reranker (chọn một) ──────────────────────────────────────
RERANKER_PROVIDER=cohere             # cohere | bge | none
COHERE_API_KEY=...
BGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANK_TOP_K=20                      # số docs đưa vào reranker
RERANK_TOP_N=5                       # số docs trả về sau rerank

# ── Tavily Web Search ────────────────────────────────────────
TAVILY_API_KEY=tvly-... #bắt buộc
TAVILY_SEARCH_DEPTH=advanced         # basic | advanced
TAVILY_MAX_RESULTS=5
WEB_SEARCH_THRESHOLD=0.4             # rerank score dưới ngưỡng → gọi Tavily

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=rag_chatbot
SESSIONS_COLLECTION=sessions
HISTORY_MAX_MESSAGES=20              # số messages giữ trong context window
HISTORY_MAX_TOKENS=4096              # trim khi tổng token vượt ngưỡng này

# ── App ──────────────────────────────────────────────────────
APP_ENV=development                  # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY="super_secret_key_for_local_development_environment_12345"
ALLOWED_ORIGINS=http://localhost:5173
API_RATE_LIMIT=60/minute             # request/phút per IP

# ── Chunking ─────────────────────────────────────────────────
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=50
